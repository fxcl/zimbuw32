    #= Open |page| in a browser, for localhost and the port number of the
    #= server.
    #- This has the effect of invoking SYS.openInBrowser() for
    #- http://localhost:{port}/{page}
    FUNC $openInBrowser(string page) status @public
      RETURN SYS.openInBrowser("http://localhost:" .. $port .. "/" .. page)
    }

    #= Tell the server to quit.
    PROC $quit() @public
      $didQuit = TRUE
      IF !$busy
        # When busy writing to the pipe is done when $busy is reset.
        # This gives the servlet a chance to send back a reply.
        $quitPipe.write(TRUE)
      }
    }

    #= Wait until the server exits.
    PROC $waitForExit() @public
      WHILE $quitPipe.read() == FALSE && !$didQuit
        # do nothing
      }
    }
  }

  #= A registered WebSocket endpoint: a path paired with the handler that is
  #- invoked once a client completes the Upgrade handshake for that path.
  CLASS WebSocketServlet @public
    string                    $path     #! exact path this endpoint answers
    proc<WebSocketConnection> $handler  #! run once per upgraded connection

    NEW(string path, proc<WebSocketConnection> handler) @public
      $path = path
      $handler = handler
    }
  }

  #= One end of an upgraded WebSocket connection.
  #- A WebSocketConnection IS a thread: its |body()| invokes the registered
  #- |$handler| once, passing THIS, and the handler owns the recv()/send() loop.
  #- recv() returns NIL when the peer closes (or on error), so a handler can
  #- loop until NIL and then return; body() always releases the socket.
  #-
  #- This is a first slice: text frames only, payloads capped at 65535 bytes,
  #- no ping/pong, continuation or fragmentation handling.  Enough to prove the
  #- end-to-end path through HTTP.Server.
  CLASS WebSocketConnection EXTENDS thread @public
    int                     $fd       #! live C socket fd, -1 once closed
    proc<WebSocketConnection> $handler  #!

    NEW(int fd, proc<WebSocketConnection> handler) @public
      $fd = fd
      $handler = handler
    }

    #= Entry point of the per-connection thread.
    #- Runs the handler, then guarantees the socket is released even if the
    #- handler returns without closing (close() is idempotent).
    PROC $body() @replace @public
      $handler(THIS)
      $close()
    }

    #= Read one text frame and return its payload.
    #- Returns NIL when the peer closed, sent a close frame, exceeded the
    #- 65535-byte cap, or on any read error; the socket is closed in that case.
    FUNC $recv() string @public
      string msg = ""
      int got = 0
>>> uses(sys_types, socket, unistd) blockgc
      {
        unsigned char hdr[2];
        int n = 0;
        while (n < 2) { int r = sckt_read(%$fd%, (char *)hdr + n, 2 - n); if (r <= 0) goto ws_done; n += r; }
        int opcode = hdr[0] & 0x0F;
        int masked = hdr[1] & 0x80;
        unsigned long long plen = hdr[1] & 0x7F;
        if (plen == 126)
        {
          unsigned char ext[2]; n = 0;
          while (n < 2) { int r = sckt_read(%$fd%, (char *)ext + n, 2 - n); if (r <= 0) goto ws_done; n += r; }
          plen = ((unsigned long long)ext[0] << 8) | ext[1];
        }
        else if (plen == 127)
        {
          unsigned char ext[8]; n = 0;
          while (n < 8) { int r = sckt_read(%$fd%, (char *)ext + n, 8 - n); if (r <= 0) goto ws_done; n += r; }
          plen = 0; int ei; for (ei = 0; ei < 8; ei++) plen = (plen << 8) | ext[ei];
        }
        if (plen > 65535) goto ws_done;
        unsigned char mask[4];
        if (masked)
        {
          n = 0;
          while (n < 4) { int r = sckt_read(%$fd%, (char *)mask + n, 4 - n); if (r <= 0) goto ws_done; n += r; }
        }
        unsigned char payload[65536];
        unsigned long long g = 0;
        while (g < plen) { int r = sckt_read(%$fd%, (char *)payload + g, (int)(plen - g)); if (r <= 0) goto ws_done; g += r; }
        if (masked) { unsigned long long j; for (j = 0; j < plen; j++) payload[j] ^= mask[j % 4]; }
        payload[plen] = 0;
        if (opcode == 0x8) goto ws_done;   /* close frame */
        %msg% = Zstr((char *)payload);
        %got% = 1;
        ws_done: ;
      }
<<<
      IF got == 1
        RETURN msg
      }
      $close()
      RETURN NIL
    }

    #= Send |text| as a single unmasked text frame.  Returns OK on success.
    FUNC $send(string text) status @public
      status ret = FAIL
>>> uses(sys_types, socket, unistd) blockgc
      {
        Tc *p;
        Ti len = ZstringSizePtr(%text%, &p);
        if (len > 65535) len = 65535;
        unsigned char out[65540];
        out[0] = 0x81;   /* FIN | text */
        int ol;
        if (len < 126) { out[1] = (unsigned char)len; ol = 2; }
        else { out[1] = 126; out[2] = (unsigned char)(len >> 8); out[3] = (unsigned char)len; ol = 4; }
        Ti i;
        for (i = 0; i < len; i++) out[ol + i] = (unsigned char)p[i];
        ol += (int)len;
        if (sckt_write(%$fd%, (char *)out, (size_t)ol) == (size_t)ol) %ret% = %OK%;
      }
<<<
      RETURN ret
    }

    #= Close the underlying socket.  Idempotent.
    PROC $close() @public
      IF $fd >= 0
>>> uses(sys_types, socket, unistd) blockgc
        { sckt_close(%$fd%); }
<<<
        $fd = -1
      }
    }
  }

  #! Return TRUE if |c| is a space or Tab.
  FUNC isWhite(int c) bool
    RETURN c == ' ' || c == '\t'
  }

}
