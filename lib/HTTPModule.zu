                    acc[oi++] = b64tab[((dig[pi] & 3) << 4) | (dig[pi+1] >> 4)];
                    acc[oi++] = b64tab[((dig[pi+1] & 15) << 2) | (dig[pi+2] >> 6)];
                    acc[oi++] = b64tab[dig[pi+2] & 63];
